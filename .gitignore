# Terraform state and provider cache
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.backup
*.tfstate.*.backup
crash.log
crash.*.log

# Secrets — never commit these
secrets.auto.tfvars
*.tfvars
!*.tfvars.example

# Generated artifacts
modules/haproxy/generated/
modules/supervisor/generated/
modules/nested-esxi/generated/
examples/avi-lb/generated/

# Avi/NSX-ALB Controller OVA — large (~5 GB), licensed, don't commit
*.ova

# vSphere install media — large, licensed, keep local only
*.iso

# macOS cruft
.DS_Store

# Local Claude Code settings
.claude/

# Per-environment generated artifacts (TLS keys, enable specs with secrets)
examples/*/generated/

# Stray working artifacts (vendor OVF descriptor, OVF-env debug dump)
controller.ovf
haproxy-ovfenv.xml
